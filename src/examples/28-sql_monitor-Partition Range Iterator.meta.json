      "ddl": "\n  CREATE TABLE \"PLANVIZ\".\"SALES_PART\" \n   (\t\"SALE_ID\" NUMBER, \n\t\"CUSTOMER_ID\" NUMBER, \n\t\"PRODUCT_ID\" NUMBER, \n\t\"STORE_ID\" NUMBER, \n\t\"SALE_DATE\" DATE NOT NULL ENABLE, \n\t\"QUANTITY\" NUMBER, \n\t\"AMOUNT\" NUMBER, \n\t CONSTRAINT \"CHK_SALES_PART_QTY\" CHECK (quantity > 0) ENABLE, \n\t CONSTRAINT \"FK_SALES_PART_PRODUCT\" FOREIGN KEY (\"PRODUCT_ID\")\n\t  REFERENCES \"PLANVIZ\".\"DIM_PRODUCTS\" (\"PRODUCT_ID\") ENABLE, \n\t CONSTRAINT \"FK_SALES_PART_STORE\" FOREIGN KEY (\"STORE_ID\")\n\t  REFERENCES \"PLANVIZ\".\"DIM_STORES\" (\"STORE_ID\") ENABLE\n   ) \n  PARTITION BY RANGE (\"SALE_DATE\") INTERVAL (NUMTOYMINTERVAL(1, 'MONTH')) \n (PARTITION \"P_2024_01\"  VALUES LESS THAN (TO_DATE(' 2024-02-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')) ) ;"
